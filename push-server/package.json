{
  "name": "coolify-companion-push-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Watches a Coolify instance and sends FCM push notifications to Coolify Companion devices.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "firebase-admin": "^13.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
