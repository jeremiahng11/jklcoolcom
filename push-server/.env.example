# --- Coolify ---
COOLIFY_URL=http://192.168.0.147:8000       # base URL (with or without /api/v1)
COOLIFY_TOKEN=your_coolify_api_token         # needs read (read:sensitive for logs)

# --- Firebase service account (pick ONE) ---
# Base64 of the service-account JSON (easiest for env-only hosts like Coolify):
#   base64 -w0 service-account.json
FIREBASE_SERVICE_ACCOUNT_BASE64=
# ...or a path to the JSON file:
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/service-account.json

# --- Server ---
PORT=8090
POLL_SECONDS=30
DATA_DIR=./data
# Optional: require this secret on /register (sent as x-register-secret header)
REGISTER_SECRET=
